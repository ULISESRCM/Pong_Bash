rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Permitir que cualquiera lea el ranking (incluso sin iniciar sesión)
      allow read: if true;
      // Solo el dueño del documento puede actualizar su ELO/apodo
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
